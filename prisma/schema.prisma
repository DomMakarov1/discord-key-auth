generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  discordId     String?   @unique
  username      String    @unique
  passwordHash  String
  rank          String    @default("Member")
  blacklisted   Boolean   @default(false)
  blacklistedUntil DateTime?
  createdAt     DateTime  @default(now())
  licenses      License[]
  keysUsed      Key[]     @relation("KeyRedeemer")
  keysAssigned  Key[]     @relation("KeyAssignee")
  sessions      Session[]
  clientCommands ClientCommand[]
  warnings      Warning[]
}

model Key {
  id            Int       @id @default(autoincrement())
  code          String    @unique
  tier          String
  durationDays  Int
  createdAt     DateTime  @default(now())
  assignedToId  Int?
  assignedTo    User?     @relation("KeyAssignee", fields: [assignedToId], references: [id])
  redeemedAt    DateTime?
  redeemedById  Int?
  redeemedBy    User?     @relation("KeyRedeemer", fields: [redeemedById], references: [id])
}

model License {
  id        Int      @id @default(autoincrement())
  userId    Int
  tier      String
  active    Boolean  @default(true)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Session {
  id             Int      @id @default(autoincrement())
  userId         Int
  tokenJti       String   @unique
  createdAt      DateTime @default(now())
  startedAt      DateTime @default(now())
  endedAt        DateTime?
  revoked        Boolean  @default(false)
  robloxUserId   String?
  robloxUsername String?
  robloxGameId   String?
  robloxPlaceId  String?
  lastIp         String?
  hwid           String?
  lastSeenAt     DateTime?
  user           User     @relation(fields: [userId], references: [id])
}

model ClientCommand {
  id             Int      @id @default(autoincrement())
  userId         Int
  action         String
  payload        Json?
  status         String   @default("pending") // pending, delivered, acknowledged, expired
  attempts       Int      @default(0)
  lastDeliveredAt DateTime?
  acknowledgedAt DateTime?
  ackStatus      String?
  ackError       String?
  createdAt      DateTime @default(now())
  expiresAt      DateTime
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId, status, createdAt])
}

model Warning {
  id               Int      @id @default(autoincrement())
  userId           Int
  message          String
  issuedByDiscordId String?
  issuedByName     String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

/// Tracks failed script-login attempts per HWID (executor fingerprint).
/// Escalation tier resets each UTC calendar day.
model HwidLoginState {
  id Int       @id @default(autoincrement())
  hwid        String    @unique
  failCount   Int       @default(0)
  /// 0 = next lockout 5m, 1 = 20m, 2 = 60m (caps at 2)
  escalation  Int       @default(0)
  lockedUntil DateTime?
  dayKey      String    @default("")
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
}

/// Blocks script login from a device (HWID and/or IP).
model AccessBan {
  id                 Int      @id @default(autoincrement())
  hwid               String?
  ip                 String?
  reason             String?
  createdByDiscordId String?
  createdAt          DateTime @default(now())

  @@index([hwid])
  @@index([ip])
}
